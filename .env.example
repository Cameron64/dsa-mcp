# Required — bearer token clients must present on /mcp. Generate a long random
# value, e.g.:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=

# Optional — Outline API token for wiki_search / wiki_document_read.
# Mint at https://wiki.austindsa.org → Settings → API Tokens (read scopes).
# Wiki tools return a "not configured" message when unset.
OUTLINE_API_TOKEN=

# Optional — Outline host (defaults to wiki.austindsa.org).
OUTLINE_HOST=wiki.austindsa.org

# Optional — GitHub token to raise the anonymous API rate limit (60/hr → 5000/hr).
# The DSA content repos are public, so this is only needed for heavy usage.
GITHUB_TOKEN=

# Optional — content cache TTL in milliseconds (default 900000 = 15 min).
REPO_CONTENT_CACHE_TTL_MS=
